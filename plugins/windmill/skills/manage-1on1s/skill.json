      "description": "Notification-config workflow for 1:1s (one-on-one-templates enabled)",
      "file": "notification.md",
      "gate": {
        "flag": "one-on-one-templates",
        "enabledWhen": true
      },
      "requiredTools": [
        "one-on-ones_query",
